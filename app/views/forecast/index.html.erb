<style>
  body {
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
    background-color: #f4f7f9;
    color: #333;
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: 100vh;
    margin: 0;
  }

  .weather-container {
    background-color: white;
    padding: 2rem 2.5rem;
    border-radius: 12px;
    box-shadow: 0 8px 30px rgba(0,0,0,0.1);
    width: 100%;
    max-width: 500px;
    text-align: center;
  }

  .weather-container h1 {
    margin-top: 0;
    margin-bottom: 1.5rem;
    color: #2c3e50;
    font-size: 2.2rem;
  }

  .search-form {
    display: flex;
    gap: 0.5rem;
    margin-bottom: 2rem;
  }

  .search-form input[type="text"] {
    flex-grow: 1;
    border: 1px solid #dcdfe6;
    border-radius: 6px;
    padding: 0.75rem;
    font-size: 1rem;
  }
  
  .search-form input[type="text"]:focus {
    outline: none;
    border-color: #4a90e2;
    box-shadow: 0 0 0 2px rgba(74, 144, 226, 0.2);
  }

  .search-form input[type="submit"] {
    background-color: #4a90e2;
    color: white;
    border: none;
    border-radius: 6px;
    padding: 0.75rem 1.5rem;
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
    transition: background-color 0.2s;
  }
  
  .search-form input[type="submit"]:hover {
    background-color: #357abd;
  }
  
  .forecast-card {
    background-color: #f8f9fa;
    border: 1px solid #e9ecef;
    border-radius: 8px;
    padding: 1.5rem;
    text-align: left;
  }

  .forecast-card h2 {
    margin-top: 0;
    margin-bottom: 1rem;
    color: #343a40;
    border-bottom: 2px solid #e9ecef;
    padding-bottom: 0.5rem;
  }

  .forecast-card p {
    margin: 0.5rem 0;
    font-size: 1.1rem;
    color: #495057;
  }
  
  .cache-indicator {
    font-style: italic;
    font-size: 0.9rem;
    color: #6c757d;
    margin-bottom: 1rem;
  }

  .error-message {
    color: #d9534f;
    font-weight: 500;
    margin-top: 1rem;
  }
</style>

<div class="weather-container">
  <h1>Weather Forecast</h1>

  <%= form_with url: root_path, method: :get, local: true, class: 'search-form' do |form| %>
    <%= form.text_field :address, value: params[:address], placeholder: "Enter ZIP Code or City" %>
    <%= form.submit "Search" %>
  <% end %>

  <% if @forecast %>
    <div class="forecast-card">
      <h2>Forecast for: <%= @forecast['name'] %></h2>

      <% if @from_cache %>
        <p class="cache-indicator">(This result was loaded from cache)</p>
      <% end %>

      <p><strong>Current Temperature:</strong> <%= @forecast['main']['temp'].round %>°C</p>
      <p><strong>Condition:</strong> <%= @forecast['weather'].first['description'].capitalize %></p>
      <p><strong>High:</strong> <%= @forecast['main']['temp_max'].round %>°C</p>
      <p><strong>Low:</strong> <%= @forecast['main']['temp_min'].round %>°C</p>
      <p><strong>Humidity:</strong> <%= @forecast['main']['humidity'] %>%</p>
    </div>
  <% elsif params[:address].present? %>
    <p class="error-message">Could not find the forecast for the provided address. Please try again.</p>
  <% end %>
</div>